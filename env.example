# --- Production / hosting (set on deploy host, not committed) ---

# Canonical public URL, no trailing slash (sitemap, robots, Open Graph).
# Example: https://researchindia.org
NEXT_PUBLIC_SITE_URL=

# Google Chat incoming webhook for contact form submissions.
# Create one in Google Chat: Space → Manage webhooks → Add webhook
# https://developers.google.com/workspace/chat/quickstart/webhooks
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX
